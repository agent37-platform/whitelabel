# =============================================================================
# Agent37 B2B Agents API  (server-side only — NEVER expose these to the browser)
# Get an sk_live_ key from your Agent37 dashboard: /dashboard/cloud/api-keys
# This ONE key is shared by the whole app. Every end-user's agents live under
# your single Agent37 workspace and are isolated per app-workspace in this app.
# =============================================================================
AGENT37_API_KEY=sk_live_replace_me
AGENT37_API_BASE_URL=https://api.agent37.com

# =============================================================================
# Supabase
# =============================================================================
# `npm run setup` uses this personal access token to run the database migration
# and configure auth for you. Create one (30 seconds) at:
#   https://supabase.com/dashboard/account/tokens
# Only needed for setup, never at runtime; it stays in this gitignored file.
SUPABASE_ACCESS_TOKEN=sbp_replace_me

# Filled in for you by `npm run setup`. Leave blank to have setup spin up a fresh
# free project, or paste an existing project's values (Project Settings -> API)
# to have setup configure that one instead.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# `npm run setup` also writes SUPABASE_DB_PASSWORD here when it creates a project.
# Like SUPABASE_ACCESS_TOKEN, it is setup-only — never add it to your deployment env.

# =============================================================================
# App
# =============================================================================
# Public base URL of THIS app (used for magic-link redirects and invite links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# White-label branding.
NEXT_PUBLIC_APP_NAME=Agent37 White-Label
# Optional path/URL to your logo (shown in the sidebar). Leave blank for none.
NEXT_PUBLIC_LOGO_URL=
